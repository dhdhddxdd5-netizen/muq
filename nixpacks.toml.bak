# Force rebuild - port fix v2
[phases.setup]
nixPkgs = ["python312", "gcc", "postgresql"]

[phases.install]
cmds = ["pip install --upgrade pip", "pip install -r requirements.txt"]

[phases.build]
cmds = ["python manage.py collectstatic --noinput", "python manage.py migrate --noinput"]

[start]
cmd = "gunicorn dalal_project.wsgi:application --bind 0.0.0.0:8080 --workers 1 --timeout 300"

[variables]
PYTHONUNBUFFERED = "1"
PORT = "8080"
